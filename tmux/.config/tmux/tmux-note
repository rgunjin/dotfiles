#!/usr/bin/env fish
set notes_dir "$HOME/notes"
mkdir -p "$notes_dir"

set existing_notes (find $notes_dir -type f -name '*.md' -exec basename {} .md \;)

set raw (printf '%s\n' $existing_notes | fzf --prompt="Note: " --print-query --layout=reverse --height=40%)

if test $status -ne 0
    exit 0
end

set lines (string split \n -- $raw)
set query (string trim -- $lines[1])    # что набрал в fzf
set selection ""
if test (count $lines) -ge 2
    set selection (string trim -- $lines[2])  # что выбрал из списка
end

# Если что-то выбрано из списка — открываем это
if test -n "$selection"
    nvim "$notes_dir/$selection.md"
# Иначе если что-то набрал — создаём новый файл
else if test -n "$query"
    nvim "$notes_dir/$query.md"
# Иначе открываем TODO
else
    nvim "$notes_dir/TODO.md"
end
